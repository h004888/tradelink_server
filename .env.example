PORT=3000
NODE_ENV=development
DATABASE_URL=mongodb://localhost:27017/tradelink
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_ROUNDS=10
AUTO_VERIFY_EMAIL=true

# SePay — thu tiền tự động qua chuyển khoản ngân hàng (xem docs.sepay.vn)
SEPAY_WEBHOOK_API_KEY=change-me-to-a-random-string
SEPAY_BANK_BIN=970436
SEPAY_ACCOUNT_NUMBER=0123456789
SEPAY_ACCOUNT_NAME=NGUYEN VAN A
# Chỉ điền nếu tài khoản ngân hàng của bạn bắt buộc dùng VA (Virtual Account) — bỏ trống nếu không dùng VA.
SEPAY_VA_NUMBER=
# Public API token (my.sepay.vn → Tạo API Token) — dùng để poll giao dịch dự phòng, phòng khi webhook không tới.
SEPAY_API_KEY=
